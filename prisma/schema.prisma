// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  courses   Course[] @relation("UserCourses")
  enrollments Enrollment[]
}

model Course {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  users       User[]    @relation("UserCourses")
  quizzes     Quiz[]
  assignments  Assignment[]
}

model Enrollment {
  id        Int    @id @default(autoincrement())
  userId    Int
  courseId  Int
  user      User   @relation(fields: [userId], references: [id])
  course    Course @relation(fields: [courseId], references: [id])
}

model Quiz {
  id          Int         @id @default(autoincrement())
  title       String
  courseId    Int
  questions   Question[]
  attempts    QuizAttempt[]
}

model Question {
  id      Int   @id @default(autoincrement())
  quizId  Int
  text    String
  quiz    Quiz  @relation(fields: [quizId], references: [id])
}

model QuizAttempt {
  id      Int   @id @default(autoincrement())
  quizId  Int
  userId  Int
  score   Float
  quiz    Quiz  @relation(fields: [quizId], references: [id])
  user    User  @relation(fields: [userId], references: [id])
}

model Assignment {
  id        Int                @id @default(autoincrement())
  title     String
  courseId  Int
  submissions AssignmentSubmission[]
}

model AssignmentSubmission {
  id              Int     @id @default(autoincrement())
  assignmentId    Int
  userId          Int
  content         String
  assignment      Assignment @relation(fields: [assignmentId], references: [id])
  user            User       @relation(fields: [userId], references: [id])
}

model Conversation {
  id       Int      @id @default(autoincrement())
  messages  Message[]
}

model Message {
  id             Int         @id @default(autoincrement())
  conversationId Int
  userId         Int
  content        String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  user           User          @relation(fields: [userId], references: [id])
}

model Notice {
  id       Int      @id @default(autoincrement())
  content  String
  users    User[]   @relation("UserNotices")
}

model Notification {
  id       Int      @id @default(autoincrement())
  content  String
  userId   Int
  user     User     @relation(fields: [userId], references: [id])
}

model LiveSession {
  id       Int      @id @default(autoincrement())
  title    String
  url      String
}

model Payment {
  id        Int     @id @default(autoincrement())
  userId    Int
  amount    Float
  user      User    @relation(fields: [userId], references: [id])
}

model UsageLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  action    String
  timestamp DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ProgressRecord {
  id        Int      @id @default(autoincrement())
  userId    Int
  courseId  Int
  progress  Float
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
}